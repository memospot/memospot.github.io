// Folder-specific settings
//
// For a full list of overridable settings, and general information on folder-specific settings,
// see the documentation: https://zed.dev/docs/configuring-zed#settings-files
//
// For the best development experience with this project, install the following extensions:
// - https://zed.dev/extensions/astro
{
  "format_on_save": "on",
  "formatter": {
    "external": {
      "command": "dprint",
      "arguments": ["fmt", "--config", ".dprint.jsonc", "--stdin", "{buffer_path}"]
    }
  },
  "file_types": {
    "GitHub Actions": [".github/workflows/*.yml"]
  },
  "languages": {
    "Astro": {
      "formatter": {
        "external": {
          "command": "dprint",
          "arguments": ["fmt", "--config", ".dprint.jsonc", "--stdin", "{buffer_path}"]
        }
      }
    },
    "JavaScript": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TypeScript": {
      "language_servers": ["biome", "!eslint", "!prettier"],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    }
  },
  "lsp": {
    "astro-language-server": {},
    "markdownlint": {
      "settings": {
        "MD013": false,
        "MD028": false,
        "MD033": false,
        "MD041": false
      }
    }
  }
}
