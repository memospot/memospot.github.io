{
  "$schema": "https://plugins.dprint.dev/dprint/dprint-plugin-json/latest/schema.json",
  "excludes": [
    "**/*.lock",
    "**/.astro/*",
    "**/.dprint/*",
    "**/.git/*",
    "**/dist/*",
    "**/node_modules/*"
  ],
  "includes": ["**/*.{astro,css,json,jsonc,md,mdx,ts,yml}", "**/justfile"],
  "lineWidth": 96,
  "indentWidth": 4,
  "plugins": [
    // DO NOT USE PRETTIER WASM. It bypasses the include rules and will mess things up.
    //
    // https://github.com/dprint/dprint-plugin-exec/releases
    "https://plugins.dprint.dev/exec-0.7.2.json@6c30bd00dfb176774ece412d0fbf149478269ecc92c55ab2d6f4116938ed993e",
    // https://github.com/dprint/dprint-plugin-biome/releases
    "https://plugins.dprint.dev/biome-0.13.0.wasm@1d7e083a32ce1a2a9a7043dda1a1b2e905aaed56b54843a4d09efe539473d903",
    // https://github.com/g-plane/malva/releases
    "https://plugins.dprint.dev/g-plane/malva-v0.16.0.wasm@1c1b31f972ef5aae052f97b6723aaf962e0175c5bbe4ba877e092512af354113",
    // https://github.com/dprint/dprint-plugin-markdown/releases
    "https://plugins.dprint.dev/markdown-0.22.1.wasm@4906fbb038977732aae0e216e4b0b957e2722f8d79282660ccb36d27dd051f17",
    // https://github.com/g-plane/markup_fmt/releases
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.3.wasm@07cebe7cebf3660d15a92ad94888f2b04903ee0c1aabbb6a5b8a018720d04568",
    // https://github.com/g-plane/pretty_yaml/releases
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm@40a2fdda7040317eb1b23520f3a00769a5571eedb049c4ca9175c1b9eeba01ae"
  ],
  "exec": {
    "commands": [
      {
        "cwd": "${configDir}",
        "command": "just --dump --justfile {{file_path}}",
        "stdin": false,
        "fileNames": "justfile",
        "exts": ["justfile"]
      }
    ]
  },
  "biome": {
    "associations": ["**/*.{js,json,jsonc,ts}"],
    "indentStyle": "space",
    "indentSize": 4,
    "lineEnding": "lf",
    "lineWidth": 96,
    "trailingComma": "none",
    "json.indentSize": 2,
    "json.indentStyle": "space",
    "json.lineWidth": 96
  },
  "malva": {
    // https://dprint.dev/plugins/malva/config/
    "associations": ["**/*.css"],
    "indentWidth": 4,
    "printWidth": 96
  },
  "markdown": {
    "associations": ["**/*.{astro,md}"],
    "lineWidth": 96
  },
  "markup": {
    "associations": ["**/*.astro"],
    "indentWidth": 2,
    "printWidth": 96,
    "astroAttrShorthand": true
  },
  "yaml": {
    // https://dprint.dev/plugins/pretty_yaml/config/
    "associations": ["**/*.yml"],
    "indentWidth": 2,
    "printWidth": 96
  }
}
